# Configuración del servidor
PORT=3001
HOST=localhost
NODE_ENV=development

# Base de datos MongoDB Atlas (en la nube)
MONGODB_URI=mongodb+srv://xarlytos:Universidades7654.@xarlytos.etwuisw.mongodb.net/university_management?retryWrites=true&w=majority&appName=xarlytos
DB_NAME=university_management

# JWT Configuration
JWT_SECRET=tu-clave-secreta-muy-segura-para-jwt-tokens
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=tu-clave-secreta-para-refresh-tokens
JWT_REFRESH_EXPIRES_IN=7d

# Encriptación
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=https://frontenduniversidades.vercel.app,http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Archivos
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Reducir ventana de rate limiting
RATE_LIMIT_WINDOW_MS=60000  # 1 minuto en lugar de 15
RATE_LIMIT_MAX=200          # Aumentar límite

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log